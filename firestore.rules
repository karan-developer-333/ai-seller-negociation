rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: leaderboard
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-50 chars)
    //   - price: number (required, positive)
    //   - date: string (required, ISO 8601)
    //   - uid: string (required, matches auth.uid)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidLeaderboardEntry(data) {
      return data.keys().hasAll(['name', 'price', 'date', 'uid']) &&
             data.keys().hasOnly(['name', 'price', 'date', 'uid']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
             data.price is number && data.price > 0 &&
             data.date is string &&
             data.uid == request.auth.uid;
    }

    match /leaderboard/{entryId} {
      // Anyone can read the leaderboard (it's public)
      allow read: if true;
      
      // Only authenticated users can create their own entries
      allow create: if isAuthenticated() && isValidLeaderboardEntry(request.resource.data);
      
      // Entries are immutable once created
      allow update, delete: if false;
    }
  }
}
